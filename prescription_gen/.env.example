# Copy to .env and fill in (never commit .env)
# Google AI Studio: https://aistudio.google.com/apikey

GEMINI_API_KEY=
# Preview / Flash models work well for JSON extraction (see AI Studio model list).
GEMINI_MODEL=gemini-3-flash-preview

# Optional: set to 1 to print Gemini diagnostics to stderr
# GEMINI_DEBUG=1

# Optional: HTTP timeout for generateContent in milliseconds (default 120000)
# GEMINI_TIMEOUT_MS=120000

# Optional: OpenAI condenser before rule extraction
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o-mini

# Copy to .env and adjust if your VEXYL-STT server uses another host/port.
VITE_VEXYL_WS_URL=ws://127.0.0.1:8091

# HTTP base for POST /conversation/transcribe (defaults from WS URL if unset).
# Set explicitly when the UI is on another origin (CORS is open on the server).
# VITE_VEXYL_HTTP_URL=http://127.0.0.1:8091

# Optional: must match VEXYL_STT_API_KEY on the server if you enable API keys.
# VITE_VEXYL_STT_API_KEY=
